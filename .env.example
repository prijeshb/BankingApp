# Application
APP_NAME="Banking REST Service"
APP_VERSION="1.0.0"
DEBUG=false

# Database — SQLite path under data/ (gitignored)
DATABASE_URL=sqlite+aiosqlite:///./data/banking.db

# JWT — generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
# Dev (Vite):     ["http://localhost:5173"]
# Docker:         ["http://localhost"]
# Production:     ["https://yourdomain.com"]
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost"]
